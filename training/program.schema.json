{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TrainingBlock",
  "description": "Blok treningowy ABC. Struktura mapuje 1:1 na Hevy API (create-routine / update-routine).",
  "type": "object",
  "required": ["block", "routines"],
  "additionalProperties": false,
  "properties": {
    "block": {
      "type": "object",
      "required": ["name", "created", "weeks"],
      "additionalProperties": false,
      "properties": {
        "name":            { "type": "string", "minLength": 1 },
        "created":         { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "weeks":           { "type": "integer", "minimum": 1 },
        "previous_block":  { "type": "string" },
        "hevy_folder_id":  { "type": "integer" },
        "changes":         { "type": "array", "items": { "type": "string" } }
      }
    },
    "routines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["week", "day", "title", "exercises"],
        "additionalProperties": false,
        "properties": {
          "week":  { "type": "integer", "minimum": 1 },
          "day":   { "type": "integer", "minimum": 1, "maximum": 3 },
          "hevy_routine_id": {
            "type": "string",
            "description": "UUID rutyny w Hevy — wypełniany po imporcie. Używany przez update-routine."
          },
          "title": {
            "type": "string",
            "description": "Format Wweek_day np. 'W1_1' = tydzień 1, dzień 1. Musi być unikalny w bloku.",
            "pattern": "^W\\d+_\\d+$"
          },
          "exercises": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/exercise" }
          }
        }
      }
    }
  },
  "definitions": {
    "exercise": {
      "type": "object",
      "required": ["exercise_template_id", "sets"],
      "additionalProperties": false,
      "properties": {
        "exercise_template_id": {
          "type": "string",
          "minLength": 1,
          "description": "Hevy exerciseTemplateId z reps.md"
        },
        "name": {
          "type": "string",
          "description": "Tylko dla czytelności — nie wysyłane do API"
        },
        "notes": {
          "type": "string",
          "description": "np. 'A — Low Bar Squat | 3×8 @ 65 kg | RPE 7'"
        },
        "superset_id": {
          "type": ["integer", "null"],
          "description": "Ćwiczenia z tym samym int tworzą superserię. null = brak superserii."
        },
        "rest_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Przerwa po serii w sekundach"
        },
        "sets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/set" }
        }
      }
    },
    "set": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["warmup", "normal", "failure", "dropset"]
        },
        "weight_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Ciężar w kg. 0 dla BW."
        },
        "reps": {
          "type": "integer",
          "minimum": 0
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Czas trwania w sekundach — zamiast reps (np. Dead Hang)"
        }
      }
    }
  }
}
