{
  "servers": {
    "hevy-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "hevy-mcp"],
      "env": {
        "HEVY_API_KEY": "${input:hevyApiKey}"
      }
    },
    "youtube_transcript": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/youtube-transcript"
      ]
    }
  },
  "inputs": [
    {
      "id": "hevyApiKey",
      "type": "promptString",
      "description": "Hevy API Key (dostępny z Hevy PRO)",
      "password": true
    }
  ]
}
